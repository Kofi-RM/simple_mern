    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.2.0",
    "mongoose": "^9.6.3",
    "password-generator": "^2.2.0"
  },
  "devDependencies": {
    "prettier": "^1.18.2"
  }
}
