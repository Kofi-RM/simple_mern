{
  "name": "simple-mern",
  "version": "0.2.0",
  "description": "the simplest MERN (MongoDB, Express, React and Node) setup",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "nodemon index.js",
    "start:prod": "node index.js",
